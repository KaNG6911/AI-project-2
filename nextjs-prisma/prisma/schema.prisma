generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {

  id String @id @unique @default(uuid()) 
  name String @unique
  isVerified Boolean @default(false)
  email String @unique
  clerkId String @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

